{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run",
  "type": "object",
  "required": [
    "run_id",
    "task_id",
    "session_id",
    "source_type",
    "status",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "session_id": { "type": "string" },
    "source_type": {
      "enum": ["selected_text", "dragged_file", "voice", "hover_input", "todo", "error_signal"]
    },
    "status": {
      "enum": ["processing", "completed"]
    },
    "started_at": { "type": ["string", "null"] },
    "finished_at": { "type": ["string", "null"] }
  }
}
