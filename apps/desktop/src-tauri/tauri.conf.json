{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CialloClaw",
  "version": "0.1.0",
  "identifier": "com.cialloclaw.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "shell-ball",
        "title": "CialloClaw Shell Ball",
        "width": 800,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "url": "shell-ball.html"
      },
      {
        "label": "dashboard",
        "title": "CialloClaw Dashboard",
        "width": 1280,
        "height": 860,
        "decorations": false,
        "visible": false,
        "url": "dashboard.html"
      }
    ]
  }
}
